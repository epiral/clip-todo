#!/usr/bin/env python3
import sys, json, sqlite3, os

raw = sys.stdin.read(); data = json.loads(raw) if raw.strip() else {}

if "from" not in data or "to" not in data:
    print(json.dumps({"error": "from and to are required"}, ensure_ascii=False))
    sys.exit(1)

db_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "data", "todo.db")
conn = sqlite3.connect(db_path)

c = conn.cursor()
c.execute("UPDATE tasks SET context = ? WHERE context = ?", [data["to"], data["from"]])
conn.commit()
updated = c.rowcount
conn.close()
print(json.dumps({"updated": updated}, ensure_ascii=False))
