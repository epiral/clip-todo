#!/usr/bin/env python3
import sys, json, sqlite3, os

try:
    raw = sys.stdin.read(); data = json.loads(raw) if raw.strip() else {}
except:
    data = {}

db_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "data", "todo.db")
conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row

include_archived = data.get("include_archived", False)
area = data.get("area")

conditions = []
params = []

if not include_archived:
    conditions.append("p.archived = 0")

if area:
    conditions.append("p.area = ?")
    params.append(area)

where = " AND ".join(conditions) if conditions else "1=1"
sql = f"""
SELECT p.*, COUNT(t.id) as task_count
FROM projects p
LEFT JOIN tasks t ON t.project_id = p.id AND t.status != 'done'
WHERE {where}
GROUP BY p.id
ORDER BY p.created_at DESC
"""

c = conn.cursor()
c.execute(sql, params)
rows = [dict(row) for row in c.fetchall()]
conn.close()
print(json.dumps(rows, ensure_ascii=False))
