#!/usr/bin/env python3
import sys, json, sqlite3, os

import select; raw = sys.stdin.read() if select.select([sys.stdin], [], [], 0.1)[0] else ""; data = json.loads(raw) if raw.strip() else {}

if "id" not in data:
    print(json.dumps({"error": "id is required"}, ensure_ascii=False))
    sys.exit(1)

db_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "data", "todo.db")
conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row

task_id = data["id"]

c = conn.cursor()
c.execute("UPDATE tasks SET status = 'inbox', completed_at = NULL WHERE id = ?", [task_id])
conn.commit()

c.execute("SELECT * FROM tasks WHERE id = ?", [task_id])
row = c.fetchone()
if row is None:
    print(json.dumps({"error": "task not found"}, ensure_ascii=False))
    sys.exit(1)
conn.close()
print(json.dumps(dict(row), ensure_ascii=False))
