#!/usr/bin/env python3
import sys, json, sqlite3, os, time

try:
    import select; raw = sys.stdin.read() if select.select([sys.stdin], [], [], 0.1)[0] else ""; data = json.loads(raw) if raw.strip() else {}
except:
    data = {}

db_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "data", "todo.db")
conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row

conditions = []
params = []

status = data.get("status")
project_id = data.get("project_id")
context = data.get("context")
today = data.get("today", False)
include_done = data.get("include_done", False)

if today:
    # UTC+8: get today's start/end timestamps
    now = time.time()
    utc8_offset = 8 * 3600
    local_time = now + utc8_offset
    day_start_local = int(local_time // 86400) * 86400
    today_start = day_start_local - utc8_offset
    today_end = today_start + 86400
    conditions.append("(priority = 0 OR (due_date >= ? AND due_date < ?))")
    params.extend([today_start, today_end])
    if not include_done:
        conditions.append("status != 'done'")
else:
    if status:
        conditions.append("status = ?")
        params.append(status)
    elif not include_done:
        conditions.append("status != 'done'")

if project_id is not None:
    conditions.append("project_id = ?")
    params.append(project_id)

if context:
    conditions.append("context = ?")
    params.append(context)

where = " AND ".join(conditions) if conditions else "1=1"
sql = f"SELECT * FROM tasks WHERE {where} ORDER BY priority ASC, created_at DESC"

c = conn.cursor()
c.execute(sql, params)
rows = [dict(row) for row in c.fetchall()]
conn.close()
print(json.dumps(rows, ensure_ascii=False))
