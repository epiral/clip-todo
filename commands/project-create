#!/usr/bin/env python3
import sys, json, sqlite3, os, time

raw = sys.stdin.read(); data = json.loads(raw) if raw.strip() else {}

if "name" not in data or not data["name"]:
    print(json.dumps({"error": "name is required"}, ensure_ascii=False))
    sys.exit(1)

db_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "data", "todo.db")
conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row

name = data["name"]
color = data.get("color", "#8b6f47")
area = data.get("area", "work")
created_at = int(time.time())

c = conn.cursor()
c.execute(
    "INSERT INTO projects (name, color, area, created_at) VALUES (?, ?, ?, ?)",
    [name, color, area, created_at]
)
conn.commit()
pid = c.lastrowid
c.execute("SELECT * FROM projects WHERE id = ?", [pid])
row = dict(c.fetchone())
conn.close()
print(json.dumps(row, ensure_ascii=False))
