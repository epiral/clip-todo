#!/usr/bin/env python3
import sys, json, sqlite3, os

import select; raw = sys.stdin.read() if select.select([sys.stdin], [], [], 0.1)[0] else ""; data = json.loads(raw) if raw.strip() else {}
sql = data['sql']
params = data.get('params', [])

script_dir = os.path.dirname(os.path.abspath(__file__))
db_path = os.path.normpath(os.path.join(script_dir, '..', 'data', 'todo.db'))
os.makedirs(os.path.dirname(db_path), exist_ok=True)

conn = sqlite3.connect(db_path)
c = conn.cursor()
c.execute(sql, params)
conn.commit()
result = {'changes': conn.total_changes, 'lastInsertRowid': c.lastrowid}
conn.close()
print(json.dumps(result, ensure_ascii=False))
