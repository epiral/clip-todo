#!/usr/bin/env python3
import sys, json, sqlite3, os
from datetime import datetime, timezone, timedelta

raw = sys.stdin.read(); data = json.loads(raw) if raw.strip() else {}

if "id" not in data:
    print(json.dumps({"error": "id is required"}, ensure_ascii=False))
    sys.exit(1)

db_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "data", "todo.db")
conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row

task_id = data["id"]
allowed = ["title", "status", "priority", "context", "project_id", "due_date", "notes", "waiting_for", "completed_at"]
sets = []
params = []

for field in allowed:
    if field in data and field != "id":
        if field == "due_date":
            val = data[field]
            if val is None:
                sets.append("due_date = NULL")
            else:
                tz = timezone(timedelta(hours=8))
                dt = datetime.strptime(val, "%Y-%m-%d").replace(tzinfo=tz)
                sets.append("due_date = ?")
                params.append(int(dt.timestamp()))
        elif field == "completed_at":
            val = data[field]
            if val is None:
                sets.append("completed_at = NULL")
            else:
                sets.append("completed_at = ?")
                params.append(int(val))
        else:
            sets.append(f"{field} = ?")
            params.append(data[field])

if not sets:
    print(json.dumps({"error": "no fields to update"}, ensure_ascii=False))
    sys.exit(1)

params.append(task_id)
sql = f"UPDATE tasks SET {', '.join(sets)} WHERE id = ?"
c = conn.cursor()
c.execute(sql, params)
conn.commit()

c.execute("SELECT * FROM tasks WHERE id = ?", [task_id])
row = c.fetchone()
if row is None:
    print(json.dumps({"error": "task not found"}, ensure_ascii=False))
    sys.exit(1)
conn.close()
print(json.dumps(dict(row), ensure_ascii=False))
